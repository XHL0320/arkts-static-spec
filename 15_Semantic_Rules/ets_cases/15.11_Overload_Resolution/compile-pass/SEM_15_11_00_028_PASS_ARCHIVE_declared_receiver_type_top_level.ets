class OverloadPass026Base {
  overload pick { pickNumber, pickString }

  pickNumber(p: number): string {
    return 'base-number'
  }

  pickString(p: string): string {
    return 'base-string'
  }
}

class OverloadPass026Derived extends OverloadPass026Base {
  pickInt(p: int): string {
    return 'derived-int'
  }

  overload pick { pickInt, pickNumber, pickString }
}

let overloadPass026Derived: OverloadPass026Derived = new OverloadPass026Derived()
let overloadPass026Base: OverloadPass026Base = overloadPass026Derived

arktest.assertEQ(overloadPass026Derived.pick(26), 'derived-int')
arktest.assertEQ(overloadPass026Base.pick(26), 'base-number')
