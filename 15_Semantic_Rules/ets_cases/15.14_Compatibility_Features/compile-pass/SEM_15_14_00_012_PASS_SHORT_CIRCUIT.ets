 * @expect compile-pass
 * @section 15.14
 * @design 规范 15.14.1：逻辑 AND/OR 的短路行为
 * @note 测试逻辑 AND/OR 的短路行为
 */

// 测试逻辑 AND/OR 的短路行为
function test_short_circuit(): void {
  // 逻辑 AND 短路
  let x: number = 0
  let y: number = 10
  
  // 如果第一个操作数为 false，则不评估第二个操作数
  if (x && y++) {
    console.log("This won't execute")
  }
  console.log("After AND short-circuit: " + y)  // 输出: 10 (y 没有递增)
    
  // 逻辑 OR 短路
  x = 10
  y = 0
    
  // 如果第一个操作数为 true，则不评估第二个操作数
  if (x || y++) {
    console.log("OR short-circuit: " + x)  // 输出: OR short-circuit: 10
  }
  console.log("After OR short-circuit: " + y)  // 输出: 0 (y 没有递增)
    
  console.log("Short-circuit test passed")
}