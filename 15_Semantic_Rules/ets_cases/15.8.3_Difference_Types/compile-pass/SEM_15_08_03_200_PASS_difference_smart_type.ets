/**
 * @id SEM_15_08_03_200_PASS_difference_smart_type
 * @expect compile-pass
 * @section 15.8.3
 * @design 规范 15.8.3：undefined排除后string的length属性访问
 * @note 正向用例：x==undefined返回0，else分支x.length安全
 */
function foo(x: string | undefined): number {
    if (x == undefined) {
        return 0;
    } else {
        return x.length;
    }
}
function main(): void {
    let r: number = foo("hello");
    console.log(`r=${r}`);
}
