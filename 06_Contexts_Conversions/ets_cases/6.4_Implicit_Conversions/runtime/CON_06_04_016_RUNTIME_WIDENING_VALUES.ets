/**
 * @id CON_06_04_016_RUNTIME_WIDENING_VALUES
 * @expect runtime
 * @section 6.4
 * @design Widening Numeric Conversion иҝҗиЎҢж—¶еҖјдҝқз•ҷ: intвҶ’long, intвҶ’double
 * @note иҝҗиЎҢж—¶з”ЁдҫӢпјҡе®һйҷ…жү§иЎҢйӘҢиҜҒ widening еҗҺеҖјдёҚеҸҳ
 */
function main(): void {
  let a: int = 42
  let b: long = a
  if (b != 42) {
    throw new Error("assertion failed: intвҶ’long 42 should remain 42")
  }

  let c: int = -10
  let d: double = c
  if (d != -10.0) {
    throw new Error("assertion failed: intвҶ’double -10 should be -10.0")
  }

  let e: byte = 100
  let f: int = e
  if (f != 100) {
    throw new Error("assertion failed: byteвҶ’int 100 should remain 100")
  }

  console.log("Widening values verified")
}
