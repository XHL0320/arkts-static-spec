/**
 * @id CON_06_04_03_017_RUNTIME_ENUM_TO_UNION
 * @expect runtime
 * @section 6.4.3
 * @design жһҡдёҫвҶ’иҒ”еҗҲзұ»еһӢзҡ„иҝҗиЎҢж—¶еҖјдҝқз•ҷ
 * @note иҝҗиЎҢж—¶з”ЁдҫӢпјҡйӘҢиҜҒжһҡдёҫвҶ’иҒ”еҗҲиҪ¬жҚў
 */
enum E { A, B, C }

function main(): void {
  let e: E = E.B
  let u: int | long = e
  if (u != 1) { throw new Error("assertion: enumвҶ’int|long should be 1, got " + u) }

  let e2: E = E.C
  let u2: int | double = e2
  if (u2 != 2) { throw new Error("assertion: enumвҶ’int|double should be 2") }

  console.log("Enum to union verified")
}
