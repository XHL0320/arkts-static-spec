/**
 * @id CON_06_04_02_014_RUNTIME_WIDENING_UNION_VALUES
 * @expect runtime
 * @section 6.4.2
 * @design Widening еҲ°иҒ”еҗҲзұ»еһӢзҡ„иҝҗиЎҢж—¶еҖјдҝқз•ҷ: shortвҶ’byte|int, byteвҶ’byte|long
 * @note иҝҗиЎҢж—¶з”ЁдҫӢпјҡйӘҢиҜҒ widening еҲ°иҒ”еҗҲеҗҺеҖјдёҚеҸҳ
 */
function main(): void {
  let s: short = 42
  let u1: byte | int = s
  if (u1 != 42) {
    throw new Error("assertion failed: short 42вҶ’byte|int, got " + u1)
  }

  let b: byte = 100
  let u2: byte | long = b
  if (u2 != 100) {
    throw new Error("assertion failed: byte 100вҶ’byte|long, got " + u2)
  }

  let i: int = 77
  let u3: byte | long = i
  if (u3 != 77) {
    throw new Error("assertion failed: int 77вҶ’byte|long, got " + u3)
  }

  console.log("Widening union values verified")
}
