/**
 * @id EXP_07_02_05_011_RUNTIME_INDEX_ASSIGN_ORDER
 * @expect runtime
 * @section 7.2.5
 * @design зҙўеј•иөӢеҖјиЎЁиҫҫејҸдёӯж•°з»„вҶ’зҙўеј•вҶ’еҖјзҡ„жұӮеҖјйЎәеәҸпјҡarr[i] = val жҢү AвҶ’IвҶ’V йЎәеәҸ
 * @note иҝҗиЎҢж—¶з”ЁдҫӢпјҡйӘҢиҜҒ Assignments Involving Indexing зҡ„жұӮеҖјйЎәеәҸ
 */
let trace: string = ""

function track(label: string): int {
  trace = trace + label
  return 1
}

let data: int[] = [0, 0, 0]

function getArr(label: string): int[] {
  trace = trace + label
  return data
}

function getIdx(label: string): int {
  trace = trace + label
  return 0
}

function getVal(label: string): int {
  trace = trace + label
  return 42
}

function main(): void {
  // getArr("A") е…ҲжұӮеҖјпјҲж•°з»„еј•з”ЁпјүпјҢ
  // з„¶еҗҺ getIdx("I") жұӮеҖјпјҲзҙўеј•пјүпјҢ
  // жңҖеҗҺ getVal("V") жұӮеҖјпјҲиөӢеҖјеҖјпјү
  // trace еә”дёә "AIV"
  getArr("A")[getIdx("I")] = getVal("V")
  if (trace != "AIV") {
    throw new Error("index assign order fail: " + trace)
  }
  if (data[0] != 42) {
    throw new Error("index assign value fail")
  }

  // еӨҚеҗҲиөӢеҖјпјҡarr[i] += val
  trace = ""
  getArr("X")[getIdx("Y")] += getVal("Z")
  if (trace != "XYZ") {
    throw new Error("compound index assign order fail: " + trace)
  }
  console.log("verified")
}
