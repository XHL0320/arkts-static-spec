/**
 * @id EXP_07_22_006_PASS_BIGINT_ADDITIVE
 * @expect compile-pass
 * @section 7.22
 * @design йӘҢиҜҒ bigint еҠ жі•/еҮҸжі• +/- зҡ„зұ»еһӢз»„еҗҲпјҡ
 *          bigint+bigintвҶ’bigint, bigint-bigintвҶ’bigint
 * @note жӯЈеҗ‘з”ЁдҫӢпјҡbigint + е’Ң - иҰҒжұӮдёӨдёӘж“ҚдҪңж•°йғҪжҳҜ bigint
 */
function main(): void {
  let a: bigint = 10n
  let b: bigint = 3n

  // bigint + bigint вҶ’ bigint
  let r1 = a + b
  let r1Type = typeof(r1)
  if (r1Type != "bigint") {
    throw new Error("bigint+bigint should be bigint, got " + r1Type)
  }

  // bigint - bigint вҶ’ bigint
  let r2 = a - b
  let r2Type = typeof(r2)
  if (r2Type != "bigint") {
    throw new Error("bigint-bigint should be bigint, got " + r2Type)
  }

  console.log("verified")
}
main()
