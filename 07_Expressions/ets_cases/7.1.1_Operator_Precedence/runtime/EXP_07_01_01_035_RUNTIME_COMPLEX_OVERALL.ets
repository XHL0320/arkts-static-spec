/**
 * @id EXP_07_01_01_035_RUNTIME_COMPLEX_OVERALL
 * @expect runtime
 * @section 7.1.1
 * @design 复杂表达式验证多种运算符优先级的综合效果
 * @note 运行时用例：综合验证多级优先级
 */
function main(): void {
  // 1 + 2 * 3 << 1 = 1 + (2*3) << 1 = 1 + 6 << 1 = 7 << 1 = 14
  let r1: int = 1 + 2 * 3 << 1
  if (r1 != 14) {
    throw new Error("assertion failed: 1+2*3<<1 != 14, got " + r1)
  }
  // (1 + 2) * 3 << 1 = 3 * 3 << 1 = 9 << 1 = 18
  let r2: int = (1 + 2) * 3 << 1
  if (r2 != 18) {
    throw new Error("assertion failed: (1+2)*3<<1 != 18, got " + r2)
  }
  // -3 ** 2 的结果
  let r3: double = -3 ** 2
  // 记录实际值对比Java/Swift
  console.log("verified")
}
