/**
 * @id EXP_07_25_02_008_PASS_FLOAT_DOUBLE_PROMOTION
 * @expect compile-pass
 * @section 7.25.2
 * @design 验证 float+double→double 提升，float-double→double。
 *         spec：结果类型是转换为后最大的类型，double 是最大数值类型。
 * @note 正向用例：float/double 混合运算类型提升
 */
function main(): void {
  let f: float = Double.toFloat(3.14)
  let d: double = 2.718281828459045

  // float + double → double
  let r1 = f + d
  let t1 = typeof(r1)
  if (t1 != "double") {
    throw new Error("float+double should be double, got " + t1)
  }

  // double + float → double
  let r2 = d + f
  let t2 = typeof(r2)
  if (t2 != "double") {
    throw new Error("double+float should be double, got " + t2)
  }

  // float - double → double
  let r3 = f - d
  let t3 = typeof(r3)
  if (t3 != "double") {
    throw new Error("float-double should be double, got " + t3)
  }

  // double - float → double
  let r4 = d - f
  let t4 = typeof(r4)
  if (t4 != "double") {
    throw new Error("double-float should be double, got " + t4)
  }

  console.log("verified")
}
main()
